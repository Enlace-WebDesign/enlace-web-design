---
import Card from "@components/shared/Card.astro";
import { Globe } from "@lucide/astro";

const { title, description, url, badge, badgeIcon: BadgeIcon } = Astro.props;

interface Props {
  title: string;
  description: string;
  url: string;
  badge: string;
  badgeIcon: any;
}
---

<Card
  class="border-gray-800 flex flex-col justify-between gap-6 h-full"
  background="gray-900"
  hoverable
>
  <!-- Fila superior: Badge + botón link -->
  <div class="flex items-center justify-between">
    <span
      class="flex items-center gap-2 bg-linear-to-br from-orange-400 to-orange-800 text-white text-xs font-bold uppercase px-3 py-1.5 rounded-full"
    >
      <BadgeIcon class="w-3.5 h-3.5" />
      {badge}
    </span>

    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="w-8 h-8 rounded-full bg-white/10
    hover:bg-white/20 flex items-center justify-center transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-4 h-4 text-white"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M7 17L17 7M17 7H7M17 7v10"></path>
      </svg>
    </a>
  </div>

  <!-- Contenido -->
  <div>
    <h3 class="text-xl font-bold text-white mb-2">{title}</h3>
    <p class="text-gray-400 text-sm leading-relaxed">{description}</p>
  </div>

  <!-- URL -->
  <div class="flex items-center gap-2 border-t border-gray-700 pt-4">
    <Globe class="w-4 h-4 text-blue-900 shrink-0" />

    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="text-gray-400 text-sm hover:text-orange-400
    transition-colors truncate"
    >
      {url.replace("https://", "")}
    </a>
  </div>
</Card>
