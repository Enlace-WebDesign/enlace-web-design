---
import Card from "@components/shared/Card.astro";

const { label, value, icon: Icon, href } = Astro.props;

interface Props {
  label: string;
  value: string;
  icon: any;
  href?: string;
}
---

<Card class="flex items-center gap-4">
  <div
    class="w-10 h-10 rounded-lg bg-gray-100 flex items-center justify-center shrink-0"
  >
    <Icon class="w-5 h-5 text-gray-600" />
  </div>
  <div>
    <p class="font-semibold text-gray-900">{label}</p>
    {
      href ? (
        <a href={href} class="text-sm text-teal-600 hover:underline">
          {value}
        </a>
      ) : (
        <p class="text-sm text-gray-600">{value}</p>
      )
    }
  </div>
</Card>
