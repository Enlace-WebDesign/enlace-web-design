---
import Wrapper from "@components/shared/Wrapper.astro";
import Container from "@components/shared/Container.astro";

const { logo, description, navLinks, phone, location, copyright } = Astro.props;

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  logo: any;
  description: string;
  navLinks: NavLink[];
  phone?: string;
  location?: string;
  instagram?: string;
  linkedin?: string;
  copyright: string;
  poweredBy?: string;
  poweredByHref?: string;
}
---

<Wrapper class="bg-gray-950 text-gray-400">
  <Container>
    <!-- Fila principal -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pb-10">
      <!-- Columna 1: Logo + descripción -->
      <div class="flex flex-col gap-4">
        <img src={logo} alt="Logo" class="w-50" />
        <p class="text-sm leading-relaxed">{description}</p>
      </div>

      <!-- Columna 2: Enlaces rápidos -->
      <div class="flex flex-col gap-4">
        <h4 class="text-white font-semibold">Enlaces Rápidos</h4>
        <ul class="flex flex-col gap-2">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm hover:text-white transition-colors underline underline-offset-4"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Columna 3: Contacto -->
      <div class="flex flex-col gap-4">
        <h4 class="text-white font-semibold">Contacto</h4>
        {
          phone && (
            <a
              href={`https://wa.me/${phone.replace(/\D/g, "")}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 text-sm hover:text-white transition-colors"
            >
              <span class="text-orange-500">●</span>
              {phone}
            </a>
          )
        }
        {
          location && (
            <div class="flex flex-col gap-1 mt-2">
              <p class="text-xs text-gray-500 uppercase tracking-wider">
                Ubicación
              </p>
              {location.split("\n").map((line: string) => (
                <p class="text-sm">{line}</p>
              ))}
            </div>
          )
        }
      </div>
    </div>

    <!-- Barra inferior -->
    <div
      class="border-t border-gray-800 py-6 flex flex-col md:flex-row items-center justify-between gap-4"
    >
      <!-- Copyright -->
      <p class="text-xs text-gray-500">{copyright}</p>
    </div>
  </Container>
</Wrapper>
