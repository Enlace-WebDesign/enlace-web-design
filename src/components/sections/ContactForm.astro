---
import Wrapper from "@components/shared/Wrapper.astro";
import Container from "@components/shared/Container.astro";
import Heading from "@components/shared/Heading.astro";
import Lead from "@components/shared/Lead.astro";
import Button from "@components/shared/Button.astro";
import ContactCard from "@components/ui/ContactCard.astro";
import { Mail, Phone, MapPin } from "@lucide/astro";

const { title, description, email, phone, address } = Astro.props;

interface Props {
  title: string;
  description?: string;
  email?: string;
  phone?: string;
  address?: string;
}
---

<Wrapper class="py-20">
  <Container>
    <div class="text-center mb-16">
      <Heading title={title} centered />
      {description && <Lead text={description} centered />}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
      <!-- Cards de contacto -->
      <div class="flex flex-col gap-4">
        {
          email && (
            <ContactCard
              label="Correo Electrónico"
              value={email}
              icon={Mail}
              href={`mailto:${email}`}
            />
          )
        }
        {
          phone && (
            <ContactCard
              label="Teléfono / WhatsApp"
              value={phone}
              icon={Phone}
              href={`https://wa.me/${phone.replace(/\D/g, "")}`}
            />
          )
        }
        {
          address && (
            <ContactCard label="Dirección" value={address} icon={MapPin} />
          )
        }
      </div>

      <!-- Formulario -->
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8">
        <form class="flex flex-col gap-4">
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1">
              <label class="text-sm font-medium text-gray-700">Nombre</label>
              <input
                type="text"
                placeholder="Nombre"
                class="border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500"
              />
            </div>
            <div class="flex flex-col gap-1">
              <label class="text-sm font-medium text-gray-700">Apellido</label>
              <input
                type="text"
                placeholder="Apellido"
                class="border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500"
              />
            </div>
          </div>

          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">Email</label>
            <input
              type="email"
              placeholder="correo@ejemplo.com"
              class="border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">Teléfono</label>
            <input
              type="tel"
              placeholder="+54 9 11 1234 5678"
              class="border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500"
            />
          </div>

          <div class="flex flex-col gap-1">
            <label class="text-sm font-medium text-gray-700">Mensaje</label>
            <textarea
              rows="4"
              placeholder="¡Hola! Quisiera consultar sobre..."
              class="border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 resize-none"
            ></textarea>
          </div>

          <Button label="Enviar" variant="primary" fullWidth />
        </form>
      </div>
    </div>
  </Container>
</Wrapper>
